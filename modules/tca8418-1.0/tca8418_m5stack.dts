/dts-v1/;
/plugin/;
// dtc -@ -I dts -O dtb -o m5stac_tca8418.dtbo  m5stac-tca8418.dts
/{
 
compatible = "brcm,bcm2837";
fragment@0 {
	target = <&gpio>;
	__overlay__ {
			tca8418_pins: tca8418_pins {
					brcm,pins = <27 17 16>;
					brcm,function = <0 1 1>;
					brcm,pull = <2 0 0>;
			};
	};
};
fragment@1 {
	target = <&i2c1>;
	__overlay__{
		tca8418@34 {
	    compatible = "m5stack,tca8418_m5stack"; 
		reg = <0x34>;
		pinctrl-names = "default";
		pinctrl-0 = <&tca8418_pins>;
		interrupt-parent = <&gpio>;
	    interrupts = <27 2>; /* 中断io 下沿触发  */
		irq-gpios = <&gpio 27 0x00>; /* 中断io 下沿触发 */
	        
		keypad,num-rows = <5>;
	    keypad,num-columns = <10>;

		tables-sel-gpio = <&gpio 17 1>;
		capslock-gpio = <&gpio 16 1>;
		switch-button-code = <73>; /* 切换按键 keycode */
		// interrupt-controller;
		/* row | column | key-code  例如: 04,08,0010 q 键 */
	        linux,keymap = <
				0x04000001
				0x04040010
				0x00000011
				0x00010012
				0x00020013
				0x00030014
				0x00040015
				0x00050016
				0x00060017
				0x00070018
				0x00080019
				0x0009000e
				0x0403000f
				0x0100001e
				0x0101001f
				0x01020020
				0x01030021
				0x01040022
				0x01050023
				0x01060024
				0x01070025
				0x01080026
				0x0109001c
				0x0401002a
				0x0200003a
				0x0201002c
				0x0202002d
				0x0203002e
				0x0204002f
				0x02050030
				0x02060031
				0x02070032
				0x02080067
				0x02090029
				0x0402001d
				0x03000038
				0x03010027
				0x03020028
				0x03030039
				0x03040033
				0x03050034
				0x03060035
				0x03070069
				0x0308006c
				0x0309006a
				>;
	        linux,keymap1 = <
				0x04000001
				0x04040002
				0x00000003
				0x00010004
				0x00020005
				0x00030006
				0x00040007
				0x00050008
				0x00060009
				0x0007000a
				0x0008000b
				0x0009000e
				0x0403000f
				0x0100003b
				0x0101003c
				0x0102003d
				0x0103003e
				0x0104003f
				0x01050040
				0x01060041
				0x01070042
				0x01080043
				0x0109001c
				0x04010036
				0x0200003a
				0x02010044
				0x02020057
				0x02030058
				0x02040066
				0x0205006b
				0x02060068
				0x0207006d
				0x02080067
				0x02090029
				0x04020061
				0x03000064
				0x0301000c
				0x0302000d
				0x03030039
				0x0304001a
				0x0305001b
				0x0306002b
				0x03070069
				0x0308006c
				0x0309006a
				>;
			};
		};
	};
 
};

