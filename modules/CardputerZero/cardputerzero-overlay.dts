// Definitions for ES8389 Audio HAT
/dts-v1/;
/plugin/;
// dtc -@ -I dts -O dtb -o es8389_m5stack.dtbo  es8389_m5stack.dts
/ {
    compatible = "brcm,bcm2835";
    
    fragment@0 {
        target = <&i2s_clk_producer>;
        __overlay__ {
            status = "okay";
        };
    };

    fragment@1 {
        target = <&gpio>;
        __overlay__ {
            st7789v_pins: st7789v_pins {
                    brcm,pins = <25>;
                    brcm,function = <1>;
                    brcm,pull = <0>;
            };
            tca8418_pins: tca8418_pins {
                    brcm,pins = <27 17 16>;
                    brcm,function = <0 1 1>;
                    brcm,pull = <2 0 0>;
            };
            spk_en_pins: spk_en_pins {
                    brcm,pins = <24>;
                    brcm,function = <1>;
                    brcm,pull = <0>;
            };
            always_high_pin: always-high {
                gpio-hog;
                gpios = <24 0>;
                output-high;
                line-name = "always-high-pin";
            };
        };
    };

    fragment@2 {
        target = <&i2c1>;
        __overlay__ {
            #address-cells = <1>;
            #size-cells = <0>;
            status = "okay";

            py32io16: gpio@4f {
                    compatible = "m5stack,py32io16";
                    reg = <0x4f>;
                    gpio-controller;
                    #gpio-cells = <2>;
                    ngpios = <16>;
                    #pwm-cells = <3>;
                    status = "okay";
            };
            es8390: es8390@10 {
                compatible = "everest,es8390";
                reg = <0x10>;
                #sound-dai-cells = <0>;
                pinctrl-names = "default";
                pinctrl-0 = <&spk_en_pins>;
                clock-names = "mclk";
                clocks = <&es8390_mclk>;
                // spk-enable-gpios = <&gpio 24 1>;
                status = "okay";
            };
			hpamp: hpamp@60 {
				compatible = "ti,tpa6130a2";
				reg = <0x60>;
                power-supply = <&hpamp_regulator>;
				status = "okay";
			};
            rx8130: rx8130@32 {
                compatible = "epson,rx8130";
                reg = <0x32>;
                status = "okay";
            };

            imu@68 {
                compatible = "bosch,bmi270";
                reg = <0x68>;
                status = "okay";
            };

            tca8418@34 {
                compatible = "m5stack,tca8418c"; 
                reg = <0x34>;
                pinctrl-names = "default";
                pinctrl-0 = <&tca8418_pins>;
                interrupt-parent = <&gpio>;
                interrupts = <27 2>; /* 中断io 下沿触发  */
                irq-gpios = <&gpio 27 0x00>; /* 中断io 下沿触发 */
                    
                keypad,num-rows = <5>;
                keypad,num-columns = <10>;

                // tables-sel-gpio = <&gpio 17 1>;
                // capslock-gpio = <&gpio 16 1>;
                tables-sel-gpio = <&py32io16 8 1>;
                capslock-gpio = <&py32io16 9 1>;


                switch-button-code = <73>; /* 切换按键 keycode */
                // interrupt-controller;
                /* row | column | key-code  例如: 04,08,0010 q 键 */
                linux,keymap = < 0x04000001 0x04040002 0x00000003 0x00010004 0x00020005 0x00030006 0x00040007 0x00050008 0x00060009 0x0007000a 0x0008000b 0x0009000e 0x0403000f 0x01000010 0x01010011 0x01020012 0x01030013 0x01040014 0x01050015 0x01060016 0x01070017 0x01080018 0x01090019 0x0401003a 0x0200001e 0x0201001f 0x02020020 0x02030021 0x02040022 0x02050023 0x02060024 0x02070025 0x02080026 0x0209001c 0x0402002a 0x0300001d 0x0301002c 0x0302002d 0x0303002e 0x0304002f 0x03050030 0x03060031 0x03070032 0x03080033 0x03090039 >;
                linux,keymap1 = < 0x04000001 0x040400b7 0x000000b8 0x000100b9 0x000200ba 0x000300bb 0x000400bc 0x000500bd 0x000600be 0x000700bf 0x000800c0 0x0009000e 0x0403000f 0x010000c1 0x010100c2 0x010200c3 0x010300c4 0x010400c5 0x010500c6 0x010600c7 0x010700c8 0x010800c9 0x010900ca 0x0401003a 0x0200001e 0x0201001f 0x02020067 0x020300cb 0x020400cc 0x020500cd 0x020600ce 0x020700cf 0x020800d0 0x0209001c 0x0402002a 0x0300001d 0x03010069 0x0302006c 0x0303006a 0x030400d1 0x030500d2 0x030600d3 0x030700d4 0x030800d5 0x03090039 >;
            };
        };
    };


    fragment@3 {
        target-path = "/";
        __overlay__ {
            es8390_mclk: es8390_mclk {
                compatible = "fixed-clock";
                #clock-cells = <0>;
                clock-frequency = <12288000>;
            };

            backlight_power: backlight-regulator {
                compatible = "regulator-fixed";
                regulator-name = "backlight-vcc";
                regulator-min-microvolt = <3300000>;
                regulator-max-microvolt = <3300000>;
                regulator-boot-on;  /* 启动时就开启 */
            };
            hpamp_regulator: hpamp-regulator {
                compatible = "regulator-fixed";
                regulator-name = "ext_3v3_out";
                regulator-min-microvolt = <3300000>;
                regulator-max-microvolt = <3300000>;
                regulator-boot-on;
            };
            backlight_pwm: backlight {
                compatible = "m5stack,pwm-backlight";
                pwms = <&py32io16 3 2000000 0>;
                
                brightness-levels = <
                    0  20000  40000  60000  80000 100000 120000 140000 160000 180000
                200000 220000 240000 260000 280000 300000 320000 340000 360000 380000
                400000 420000 440000 460000 480000 500000 520000 540000 560000 580000
                600000 620000 640000 660000 680000 700000 720000 740000 760000 780000
                800000 820000 840000 860000 880000 900000 920000 940000 960000 980000
                1000000 1020000 1040000 1060000 1080000 1100000 1120000 1140000 1160000 1180000
                1200000 1220000 1240000 1260000 1280000 1300000 1320000 1340000 1360000 1380000
                1400000 1420000 1440000 1460000 1480000 1500000 1520000 1540000 1560000 1580000
                1600000 1620000 1640000 1660000 1680000 1700000 1720000 1740000 1760000 1780000
                1800000 1820000 1840000 1860000 1880000 1900000 1920000 1940000 1960000 1980000
                2000000
                >;
                default-brightness-level = <75>;
                
                power-supply = <&backlight_power>;
                /* 强制初始化时开启背光 */
                force-enable-on-init;
            };

            sound {
                compatible = "simple-audio-card"; 
                simple-audio-card,name = "ES8388-Audio";
                status = "okay";
                
                simple-audio-card,dai-link {
                    format = "i2s";
                    bitclock-master = <&dailink0_master>;
                    frame-master = <&dailink0_master>;
                    
                    dailink0_master: cpu {
                        sound-dai = <&i2s_clk_producer>;
                    };
                    
                    dailink0_slave: codec {
                        sound-dai = <&es8390>;
                    };
                };
            };

            // sound {
            //     compatible = "simple-audio-card";
            //     simple-audio-card,name = "ES8390-HPAMP";
            //     status = "okay";
                
            //     /* 将hpamp作为辅助设备添加 */
            //     simple-audio-card,aux-devs = <&hpamp>;
                
            //     /* 音频路由配置 */
            //     simple-audio-card,widgets =
            //         "Headphone", "Headphones",
            //         "Headphone", "HP Amp";
                
            //     simple-audio-card,routing =
            //         "HP Amp", "HPOUTL",
            //         "HP Amp", "HPOUTR",
            //         "Headphones", "HP Amp";
                
            //     simple-audio-card,dai-link {
            //         format = "i2s";
            //         bitclock-master = <&dailink0_master>;
            //         frame-master = <&dailink0_master>;
                    
            //         dailink0_master: cpu {
            //             sound-dai = <&i2s_clk_producer>;
            //         };
                    
            //         dailink0_slave: codec {
            //             sound-dai = <&es8390>;
            //         };
            //     };
            // };










        };
        
    };

    fragment@4 {
        target = <&spi0>;
        __overlay__ {
            status = "okay";

            #address-cells = <1>;
            #size-cells = <0>;

            st7789v@0 {
                compatible = "sitronix,st7789v_m5stack";
                reg = <0>;
                pinctrl-names = "default";
                pinctrl-0 = <&st7789v_pins>;
                backlight = <&backlight_pwm>;


                spi-max-frequency = <50000000>;
                txbuflen = <32768>;
                
                dc-gpios = <&gpio 25 0>;
                // reset-gpios = <&py32io16 4 1>;

                ram-x-offset = <0>;
                ram-y-offset = <35>;

                buswidth = <8>;
                width = <170>;
                height = <320>;
                rotate = <90>;
                fps = <60>;
                // bgr;
                
                debug = <0>;
            };
        };
    };

    fragment@5 {
        target = <&spidev0>;
        __overlay__ {
            status = "disabled";
        };
    };

























};












